# =============================================================================
# Mimir — environment variables (copy to .env.local; never commit secrets)
#
# Target chain: Mantle Sepolia (chain id 5003). Stakes are paid in native MNT.
# =============================================================================

# ── Mantle contract ───────────────────────────────────────────────────────────
# Deployed Mimir.sol address on Mantle Sepolia.
# Set automatically by: npm run deploy:contract
# NEXT_PUBLIC_CONTRACT_ADDRESS=0x...

# Block number where the contract was deployed. The /agents and /stats pages
# scan event logs starting from here. Leave unset to scan from genesis.
# NEXT_PUBLIC_DEPLOY_BLOCK=

# Set NEXT_PUBLIC_MANTLE_MAINNET=1 to target Mantle mainnet (chain 5000)
# instead of Sepolia. Defaults to Sepolia.
# NEXT_PUBLIC_MANTLE_MAINNET=

# Mantle RPC override (defaults to https://rpc.sepolia.mantle.xyz).
# Use your provider-issued endpoint (Alchemy / QuickNode / Tenderly) here.
# NEXT_PUBLIC_MANTLE_RPC=https://rpc.sepolia.mantle.xyz
# MANTLE_RPC=https://rpc.sepolia.mantle.xyz   # server-only

# ── ERC-8004 agent identity registry (Mantle) ─────────────────────────────────
# Mantle's official ERC-8004 IdentityRegistry deployment. Each Mimir agent
# registers against it on startup and the resulting tokenId is mirrored into
# Mimir.sol via registerAgent(...) for on-chain attribution.
# ERC8004_IDENTITY_REGISTRY=0x8004A818BFB912233c491871b3d84c89A494BD9e

# ── Agent wallets ─────────────────────────────────────────────────────────────
# Generate fresh private keys with:  npm run agent:wallets
# Fund both addresses with testnet MNT:  https://faucet.sepolia.mantle.xyz
# ORACLE_PRIVATE_KEY=0x...
# ORACLE_ADDRESS=0x...
# MARKET_CREATOR_PRIVATE_KEY=0x...
# MARKET_CREATOR_ADDRESS=0x...

# Deployer key used by scripts/deploy.ts. Can be reused from one of the agents
# or be a single-use throwaway key.
# DEPLOYER_PRIVATE_KEY=0x...

# ── Oracle AI agent ───────────────────────────────────────────────────────────
# Required: ORACLE_PRIVATE_KEY + ONE of GEMINI_API_KEY / ANTHROPIC_API_KEY.
# Force a specific provider with LLM_PROVIDER=gemini|anthropic.
# Override the default model with ORACLE_LLM_MODEL.
# GEMINI_API_KEY=...                       # https://aistudio.google.com/apikey
# Optional extra Gemini keys — the LLM client round-robins across them and
# rotates to the next on a 429, so you don't hit per-key rate limits.
# GEMINI_API_KEY (above) may also be a comma-separated list of keys.
# GEMINI_API_KEY_2=...
# GEMINI_API_KEY_3=...
# ANTHROPIC_API_KEY=sk-ant-...             # https://console.anthropic.com
# LLM_PROVIDER=gemini
# ORACLE_LLM_MODEL=gemini-2.5-flash        # or claude-sonnet-4-6

# Auto-challenger: oracle automatically Kelly-stakes on mispriced open claims.
# AUTO_CHALLENGE=1
# CHALLENGE_STAKE_MNT=2          # MNT per challenge (default: 2)
# CHALLENGE_CONFIDENCE=80        # min confidence % to auto-stake (default: 80)

# ── Council (10 AI personas that bet with their own wallets) ──────────────────
# Provision 10 local persona keys with:  npm run council:wallets
# Writes COUNCIL_<SLUG>_PRIVATE_KEY / COUNCIL_<SLUG>_ADDRESS for each persona:
#   OPTIMIST, PESSIMIST, CONTRARIAN, STATISTICIAN, WHALE_WATCHER, CRYPTO_MAXI,
#   SPORTS_PUNDIT, WEATHERMAN, DOOMER, YAPPER.
# Fund every address with testnet MNT (≥ ~6 MNT each) before running the council.
# COUNCIL_OPTIMIST_PRIVATE_KEY=0x...
# COUNCIL_OPTIMIST_ADDRESS=0x...
# ...one pair per persona...
# COUNCIL_GEMINI_API_KEY=...           # optional: separate LLM key/quota for the council
# COUNCIL_PERSONAS_ACTIVE=optimist,contrarian,crypto-maxi   # optional CSV to restrict roster
# COUNCIL_POLL_INTERVAL_MS=180000      # default 3 min
# COUNCIL_MAX_CLAIMS=12                 # max claims evaluated per cycle
# COUNCIL_LLM_THROTTLE_MS=4500          # min ms between persona LLM calls

# ── Bybit price feed (Track 1 settlement source) ──────────────────────────────
# Public endpoint, no auth needed for spot tickers.
# BYBIT_API_BASE=https://api.bybit.com

# ── Demo mode (no MetaMask needed) ────────────────────────────────────────────
# NEXT_PUBLIC_DEMO_MODE=1
# NEXT_PUBLIC_DEMO_MODE_LABEL=Mantle Sepolia demo
# DEMO_CREATOR_PRIVATE_KEY=0x...
# DEMO_CHALLENGER_PRIVATE_KEY=0x...
# DEMO_SIGNER_PRIVATE_KEY=0x...     # fallback for all actions

# ── XMTP messaging (E2E encrypted chat) ───────────────────────────────────────
# NEXT_PUBLIC_XMTP_ENV=dev          # local | dev | production
# NEXT_PUBLIC_FEATURE_XMTP=1
# NEXT_PUBLIC_XMTP_APP_VERSION=mimir/0.2.0

# ── Neon Postgres (server-side read index, optional) ──────────────────────────
# Contract state is always the source of truth. Neon is a cache/read index used
# by /explorer, /dashboard, and the challenge-opportunities API. Mimir boots
# fine without it — the affected routes return 500 and other pages still work.
# DATABASE_URL=postgresql://<user>:<pwd>@<host>/<db>?sslmode=require
# CRON_SECRET=

# ── Claim generation (AI-assisted create flow) ────────────────────────────────
# NEXT_PUBLIC_FEATURE_SOURCE_DRAFTS=1
# CLAIM_DRAFT_MODEL=gemini-2.5-flash

# ── Moderation ────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_FEATURE_CLAIM_MODERATION=1
# CLAIM_MODERATION_MODEL=gemini-2.5-flash
